# K8s Secrets Template for AI Work Copilot
# Usage:
#   1. Copy this file: cp secrets.yaml.template secrets.yaml
#   2. Replace placeholder values with base64-encoded secrets:
#      echo -n 'your-value' | base64
#   3. Apply: kubectl apply -f secrets.yaml
#
# IMPORTANT: Do NOT commit secrets.yaml to git!

---
apiVersion: v1
kind: Secret
metadata:
  name: jwt-secret
  namespace: workcopilot
type: Opaque
data:
  # echo -n 'your-jwt-secret-key-minimum-256-bits-long' | base64
  JWT_SECRET: <BASE64_ENCODED_JWT_SECRET>

---
apiVersion: v1
kind: Secret
metadata:
  name: google-oauth
  namespace: workcopilot
type: Opaque
data:
  # echo -n 'your-google-client-id' | base64
  GOOGLE_CLIENT_ID: <BASE64_ENCODED_GOOGLE_CLIENT_ID>
  # echo -n 'your-google-client-secret' | base64
  GOOGLE_CLIENT_SECRET: <BASE64_ENCODED_GOOGLE_CLIENT_SECRET>

---
apiVersion: v1
kind: Secret
metadata:
  name: openai-secret
  namespace: workcopilot
type: Opaque
data:
  # echo -n 'your-openai-api-key' | base64 (optional - leave empty if using Ollama only)
  OPENAI_API_KEY: <BASE64_ENCODED_OPENAI_API_KEY>
